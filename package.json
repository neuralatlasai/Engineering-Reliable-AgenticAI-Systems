{
  "name": "engineering-reliable-agentic-ai-systems",
  "version": "0.1.0",
  "private": true,
  "description": "A deterministic, source-preserving compiler and reader for arbitrary Markdown corpora.",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "npm run compile:content && next dev",
    "compile:content": "tsx src/compiler/cli.ts --config book.config.ts",
    "compile:verify": "tsx scripts/verify-determinism.ts",
    "build": "npm run compile:content && next build",
    "build:static": "npm run compile:content && cross-env BOOK_DEPLOYMENT=static next build",
    "serve:static": "tsx scripts/serve-static.ts",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "check": "npm run format:check && npm run typecheck && npm run lint && npm run test:coverage && npm run compile:verify",
    "audit:dependencies": "npm audit --audit-level=high"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "1.1.19",
    "katex": "0.17.0",
    "lucide-react": "1.24.0",
    "next": "16.2.10",
    "next-themes": "0.4.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/katex": "0.16.8",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/sanitize-html": "2.16.1",
    "@vitest/coverage-v8": "4.1.10",
    "cross-env": "10.1.0",
    "eslint": "9.39.2",
    "eslint-config-next": "16.2.10",
    "fast-check": "4.9.0",
    "iconv-lite": "0.7.3",
    "jsdom": "29.1.1",
    "mdast-util-to-string": "4.0.0",
    "micromatch": "4.0.8",
    "prettier": "3.9.5",
    "prettier-plugin-tailwindcss": "0.8.0",
    "remark-directive": "4.0.0",
    "remark-frontmatter": "5.0.0",
    "remark-gfm": "4.0.1",
    "remark-math": "6.0.0",
    "remark-mdx": "3.1.1",
    "remark-parse": "11.0.0",
    "sanitize-html": "2.17.6",
    "shiki": "4.3.1",
    "smol-toml": "1.7.0",
    "tailwindcss": "4.3.2",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "unified": "11.0.5",
    "unist-util-visit": "5.1.0",
    "vitest": "4.1.10",
    "yaml": "2.9.0"
  }
}
